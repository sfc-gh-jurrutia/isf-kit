# Snowflake Configuration
SNOWFLAKE_ACCOUNT=your-account-identifier
SNOWFLAKE_DATABASE=SANDBOX_DB
SNOWFLAKE_SCHEMA=SANDBOX_SCHEMA
SNOWFLAKE_WAREHOUSE=SANDBOX_WH

# OAuth Token for Cortex Agent REST API
# Get this via Snowflake OAuth flow or PAT (Personal Access Token)
SNOWFLAKE_OAUTH_TOKEN=your-oauth-token

# OpenAI API Key (for LangGraph orchestration LLM)
OPENAI_API_KEY=your-openai-api-key
