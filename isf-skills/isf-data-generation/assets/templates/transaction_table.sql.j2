{# Transaction Table DDL Template #}
{# Usage: Render with industry config to generate CREATE TABLE statement #}

-- {{ experience_name }} Transaction Table
-- Generated from industry_data_generator template

CREATE TABLE IF NOT EXISTS {{ database }}.{{ transactions.schema }}.{{ transactions.table }} (
    -- Standard Transaction Columns (framework required)
    TRANSACTION_ID      VARCHAR(50) NOT NULL,
    CUSTOMER_ID         VARCHAR(50) NOT NULL,
    TRANSACTION_TYPE    VARCHAR(50) NOT NULL,
    PRODUCT_ID          VARCHAR(50),
    SKU_ID              VARCHAR(50),
    AMOUNT              DECIMAL(10,2) NOT NULL,
    CURRENCY            VARCHAR(3) DEFAULT 'USD',
    TRANSACTION_STATUS  VARCHAR(20) DEFAULT 'COMPLETED',
    PAYMENT_METHOD      VARCHAR(50),
    TRANSACTION_DATE    TIMESTAMP_NTZ NOT NULL,
    CREATED_AT          TIMESTAMP_NTZ DEFAULT CURRENT_TIMESTAMP(),
    
    -- Domain-Specific Columns
{% for field in transactions.domain_fields %}
    {{ field.name.ljust(20) }} {{ field.type }}{% if field.nullable %} NULL{% else %} NOT NULL{% endif %}{% if field.default %} DEFAULT {{ field.default }}{% endif %}{% if not loop.last %},{% endif %}

{% endfor %}
    
    -- Constraints
    PRIMARY KEY (TRANSACTION_ID)
);

-- Create index on customer_id for joins
CREATE INDEX IF NOT EXISTS idx_{{ transactions.table | lower }}_customer 
ON {{ database }}.{{ transactions.schema }}.{{ transactions.table }} (CUSTOMER_ID);

-- Create index on transaction_date for time-based queries
CREATE INDEX IF NOT EXISTS idx_{{ transactions.table | lower }}_date 
ON {{ database }}.{{ transactions.schema }}.{{ transactions.table }} (TRANSACTION_DATE);

-- Create index on transaction_type for filtering
CREATE INDEX IF NOT EXISTS idx_{{ transactions.table | lower }}_type 
ON {{ database }}.{{ transactions.schema }}.{{ transactions.table }} (TRANSACTION_TYPE);

-- Add comment
COMMENT ON TABLE {{ database }}.{{ transactions.schema }}.{{ transactions.table }} IS 
'{{ experience_name }} financial transactions. Generated by industry_data_generator.';
