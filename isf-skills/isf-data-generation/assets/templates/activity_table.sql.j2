{# Activity Table DDL Template #}
{# Usage: Render with industry config to generate CREATE TABLE statement #}

-- {{ experience_name }} Activity Table
-- Generated from industry_data_generator template

CREATE TABLE IF NOT EXISTS {{ database }}.{{ activity.schema }}.{{ activity.table }} (
    -- Standard Activity Columns (framework required)
    ACTIVITY_ID         VARCHAR(50) NOT NULL,
    CUSTOMER_ID         VARCHAR(50) NOT NULL,
    ACTIVITY_TYPE       VARCHAR(50) NOT NULL,
    CONTENT_ID          VARCHAR(50),
    PRODUCT_ID          VARCHAR(50),
    CATEGORY            VARCHAR(100),
    DEVICE_TYPE         VARCHAR(50),
    SESSION_ID          VARCHAR(50),
    REFERRAL_SOURCE     VARCHAR(100),
    EVENT_TIMESTAMP     TIMESTAMP_NTZ NOT NULL,
    IP_ADDRESS          VARCHAR(50),
    DEVICE_ID           VARCHAR(50),
    CREATED_AT          TIMESTAMP_NTZ DEFAULT CURRENT_TIMESTAMP(),
    
    -- Domain-Specific Columns
{% for field in activity.domain_fields %}
    {{ field.name.ljust(20) }} {{ field.type }}{% if field.nullable %} NULL{% else %} NOT NULL{% endif %}{% if field.default %} DEFAULT {{ field.default }}{% endif %}{% if not loop.last %},{% endif %}

{% endfor %}
    
    -- Constraints
    PRIMARY KEY (ACTIVITY_ID)
);

-- Create index on customer_id for joins
CREATE INDEX IF NOT EXISTS idx_{{ activity.table | lower }}_customer 
ON {{ database }}.{{ activity.schema }}.{{ activity.table }} (CUSTOMER_ID);

-- Create index on timestamp for time-based queries
CREATE INDEX IF NOT EXISTS idx_{{ activity.table | lower }}_timestamp 
ON {{ database }}.{{ activity.schema }}.{{ activity.table }} (EVENT_TIMESTAMP);

-- Add comment
COMMENT ON TABLE {{ database }}.{{ activity.schema }}.{{ activity.table }} IS 
'{{ experience_name }} activity/behavioral events. Generated by industry_data_generator.';
