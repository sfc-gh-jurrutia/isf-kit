### Governance Tool Templates

```
-- explain_lineage
CREATE OR REPLACE PROCEDURE EXPLAIN_LINEAGE(object_name VARCHAR)
RETURNS TABLE(source VARCHAR, transform VARCHAR, description VARCHAR, owner VARCHAR)
LANGUAGE SQL
AS
$$
  SELECT source_table, transform_type, description, business_owner
  FROM LINEAGE_METADATA
  WHERE target_table ILIKE object_name
  ORDER BY lineage_order
$$;

-- check_data_quality  
CREATE OR REPLACE PROCEDURE CHECK_DATA_QUALITY(table_name VARCHAR)
RETURNS TABLE(metric VARCHAR, value VARCHAR, status VARCHAR)
LANGUAGE SQL
AS
$$
  SELECT metric_name, metric_value, 
         CASE WHEN metric_value >= threshold THEN 'PASS' ELSE 'WARN' END
  FROM DATA_QUALITY_METRICS
  WHERE table_name ILIKE table_name
$$;
```

